{
  "name": "margin",
  "version": "1.0.0",
  "description": "A calm Chrome extension for reading PDFs — highlights, flashcards, SM-2.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "clean": "rm -rf dist",
    "test:fixtures": "bun run test/generate-fixtures.ts",
    "test": "bun run test/harness.ts"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "pdfjs-dist": "4.7.76",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@types/chrome": "0.0.270",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
